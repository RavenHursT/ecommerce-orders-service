generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["eos"]
}

enum OrderStatus {
  PENDING
  PROCESSING
  FULFILLABLE
  PAYMENT_COMPLETE
  UNFULFILLABLE
  PAYMENT_FAILED
  CANCELLED

  @@schema("eos")
}

enum PaymentAuthorizationStatus {
  AUTHORIZED
  DECLINED

  @@schema("eos")
}

model Order {
  id                     String      @id @default(cuid())
  status                 OrderStatus @default(PENDING)
  customerName           String      @map("customer_name")
  customerEmail          String      @map("customer_email")
  shippingLine1          String      @map("shipping_line1")
  shippingLine2          String?     @map("shipping_line2")
  shippingCity           String      @map("shipping_city")
  shippingState          String      @map("shipping_state")
  shippingPostalCode     String      @map("shipping_postal_code")
  shippingCountry        String      @map("shipping_country")
  totalAmount            Decimal     @map("total_amount") @db.Decimal(10, 2)
  warehouseId            String?     @map("warehouse_id")
  paymentAuthorizationId String?     @map("payment_authorization_id")
  warehouseName          String?     @map("warehouse_name")
  distanceKm             Decimal?    @map("distance_km") @db.Decimal(10, 3)
  estimatedShipment      Json?       @map("estimated_shipment")
  unfulfillableReason    String?     @map("unfulfillable_reason")
  createdAt              DateTime    @default(now()) @map("created_at")
  updatedAt              DateTime    @updatedAt @map("updated_at")

  items OrderItem[]

  @@map("orders")
  @@schema("eos")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String  @map("order_id")
  productId String  @map("product_id")
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
  @@schema("eos")
}

model Warehouse {
  id        String @id @default(cuid())
  name      String
  address   String
  latitude  Float
  longitude Float

  inventory WarehouseInventory[]

  @@map("warehouses")
  @@schema("eos")
}

model Product {
  id        String  @id @default(cuid())
  sku       String  @unique
  name      String
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)

  inventory  WarehouseInventory[]
  orderItems OrderItem[]

  @@map("products")
  @@schema("eos")
}

model WarehouseInventory {
  warehouseId String @map("warehouse_id")
  productId   String @map("product_id")
  quantity    Int

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([warehouseId, productId])
  @@map("warehouse_inventory")
  @@schema("eos")
}

model PaymentAuthorization {
  id                String                     @id @default(cuid())
  orderId           String                     @map("order_id")
  amount            Decimal                    @db.Decimal(10, 2)
  cardLastFour      String                     @map("card_last_four") @db.VarChar(4)
  description       String?
  status            PaymentAuthorizationStatus
  authorizationCode String?                    @map("authorization_code")
  createdAt         DateTime                   @default(now()) @map("created_at")

  @@index([orderId])
  @@map("payment_authorizations")
  @@schema("eos")
}
